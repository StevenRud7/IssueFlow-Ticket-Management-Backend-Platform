# ---------- Application ----------
NODE_ENV=development
PORT=3000

# ---------- Database ----------
# Matches the credentials in compose.yml. Override for production.
DATABASE_URL=postgresql://issueflow:issueflow@localhost:5432/issueflow
# Connection pool tuning
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_TIMEOUT_MS=30000

# ---------- JWT ----------
# CHANGE THIS in production. Anything > 32 random bytes is fine for local dev.
JWT_SECRET=change-me-to-a-long-random-string-for-local-dev-only
# Token lifetime; format accepts ms-style strings ("1h", "30m") or seconds ("3600")
JWT_EXPIRES_IN=3600

# ---------- Uploads (Phase 8) ----------
UPLOAD_DIR=./uploads
UPLOAD_MAX_BYTES=10485760

# ---------- Auto-escalation scheduler (Phase 7) ----------
# Crontab expression. Default: top of every hour.
ESCALATION_CRON=0 * * * *

# Set to false to disable the interactive Swagger UI at /docs
SWAGGER_ENABLED=true
